{
  "name": "@cbaileydev/garage-copilot-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Garage Copilot Desktop — a cross-platform GUI that plugs into your car's OBD-II port (via Web Serial) to diagnose, monitor, and tune-advise. Built on the Garage Copilot engine; reads only.",
  "author": "CBaileyDev",
  "homepage": "https://github.com/CBaileyDev/MCPs",
  "main": "dist/main/main.cjs",
  "scripts": {
    "build:core": "npm --prefix ../garage-copilot run build",
    "build:app": "node esbuild.mjs",
    "build": "npm run build:core && npm run build:app",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && electron .",
    "app": "electron .",
    "dist": "npm run build && electron-builder",
    "smoke": "electron scripts/smoke.cjs",
    "stress": "electron scripts/stress.cjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@types/node": "^24.0.0",
    "@types/w3c-web-serial": "^1.0.6",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
