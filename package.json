{
  "name": "deepscan",
  "version": "0.1.0",
  "description": "Professional read-only automotive diagnostics: CLI engine + Electron desktop app",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/garage-copilot",
    "apps/garage-copilot-desktop"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "pretypecheck": "npm run build --workspace=@deepscan/engine",
    "typecheck": "npm run typecheck --workspaces",
    "pretest": "npm run build --workspace=@deepscan/engine",
    "test": "npm run test --workspaces",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
